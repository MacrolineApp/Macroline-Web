---
import CookieNotice from '../components/CookieNotice.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Macroline — Just say what you ate.',
  description = 'The AI-native macro & calorie tracker. Describe a meal in plain language, scan a barcode, or connect Claude. Every food has a verified source.',
  ogImage = '/og.png',
} = Astro.props;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `https://macroline.app${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0F172A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://macroline.app${Astro.url.pathname}`} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body>
    <header class="site-header" data-nav-open="false">
      <a href="/" class="brand">
        <svg class="brand-mark" viewBox="0 0 24 18" width="24" height="18" aria-hidden="true">
          <rect x="1"  y="6.84" width="5" height="11.16" rx="2.5" fill="var(--protein)" />
          <rect x="9.5" y="0"  width="5" height="18"    rx="2.5" fill="var(--carbs)" />
          <rect x="18" y="3.96" width="5" height="14.04" rx="2.5" fill="var(--fat)" />
        </svg>
        <span class="brand-name">macroline</span>
      </a>
      <button
        type="button"
        class="nav-toggle"
        aria-controls="primary-nav"
        aria-expanded="false"
        aria-label="Open navigation"
      >
        <span class="nav-toggle-bars" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <nav id="primary-nav" class="primary-nav">
        <a href="/features">Features</a>
        <a href="/pricing">Pricing</a>
        <a href="/blog">Blog</a>
        <a href="https://my.macroline.app/login" class="nav-login">Log in</a>
      </nav>
    </header>

    <script>
      // Mobile nav toggle. Vanilla JS; runs once on page load. Toggling the
      // data-nav-open attribute on the header is what flips the CSS state.
      const header = document.querySelector('.site-header');
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.getElementById('primary-nav');
      if (header && toggle && nav) {
        const setOpen = (open: boolean) => {
          header.setAttribute('data-nav-open', String(open));
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
        };
        toggle.addEventListener('click', () => {
          const open = header.getAttribute('data-nav-open') === 'true';
          setOpen(!open);
        });
        // Close the menu when a nav link is tapped — feels more like a real
        // navigation surface than leaving the drawer open after a route change.
        nav.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => setOpen(false));
        });
        // Esc closes the drawer.
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && header.getAttribute('data-nav-open') === 'true') {
            setOpen(false);
            (toggle as HTMLButtonElement).focus();
          }
        });
      }
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <svg viewBox="0 0 24 18" width="22" height="17" aria-hidden="true">
              <rect x="1"    y="6.84" width="5" height="11.16" rx="2.5" fill="var(--protein)" />
              <rect x="9.5"  y="0"    width="5" height="18"    rx="2.5" fill="var(--carbs)" />
              <rect x="18"   y="3.96" width="5" height="14.04" rx="2.5" fill="var(--fat)" />
            </svg>
            <span>macroline</span>
          </a>
          <p class="footer-tag">The AI-native macro tracker. Just say what you ate.</p>
          <a class="footer-blog-cta" href="/blog">
            <span class="footer-blog-cta-title">Notes from the macro lab.</span>
            <span class="footer-blog-cta-sub">Twice-weekly posts on macros, GLP-1, and the science of food data.</span>
            <span class="footer-blog-cta-link">Read the blog →</span>
          </a>
        </div>
        <nav class="footer-links" aria-label="Footer">
          <div class="footer-col">
            <h4>Product</h4>
            <a href="/features">Features</a>
            <a href="/pricing">Pricing</a>
            <a href="/connect-claude">Connect Claude</a>
            <a href="https://my.macroline.app/login">Log in</a>
          </div>
          <div class="footer-col">
            <h4>Company</h4>
            <a href="/blog">Blog</a>
            <a href="/support">Support</a>
            <a href="mailto:info@macroline.app">info@macroline.app</a>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </div>
        </nav>
      </div>
      <div class="footer-baseline">
        <span>© {new Date().getFullYear()} Macroline. All rights reserved.</span>
        <span class="status-line">
          <a href="https://apps.apple.com/us/app/macroline/id6765770579" target="_blank" rel="noopener">Now on the App Store</a>
          <span aria-hidden="true"> · </span>
          <a href="https://my.macroline.app">Web app</a>
        </span>
      </div>
    </footer>

    <CookieNotice />
  </body>
</html>

<style is:global>
  :root {
    --bg: #FAFAFA;
    --surface: #FFFFFF;
    --surface-2: #F1F5F9;
    --text: #0F172A;
    --text-muted: #64748B;
    --border: #E2E8F0;
    --primary: #1E40AF;
    --primary-hover: #1D4ED8;
    --accent: #5B9EFF;
    --protein: #F08E3A;
    --carbs:   #F0B020;
    --fat:     #8B6DFF;
    --r-md: 12px;
    --r-lg: 18px;
    --r-pill: 999px;
  }

  /* Brand-navy dark mode — matches the iOS app's blue theme so users
     who keep the OS in dark mode see Macroline's navy palette, not
     generic black. */
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0A1628;
      --surface: #142242;
      --surface-2: #1F2A45;
      --text: #F8FAFC;
      --text-muted: #94B3D7;
      --border: rgba(96, 165, 250, 0.15);
      --primary: #5B9EFF;
      --primary-hover: #76B6FF;
    }
  }

  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  a { color: var(--primary); text-decoration: none; }
  a:hover { text-decoration: underline; }

  h1, h2, h3 {
    font-family: 'Inter Display', 'Inter', sans-serif;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px 24px;
    position: relative;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 18px;
  }
  .brand-mark {
    display: inline-block;
    vertical-align: middle;
  }
  .brand-name { font-family: 'Inter Display', 'Inter', sans-serif; }

  /* Desktop nav (default — links inline at the right edge). */
  .site-header .primary-nav {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .site-header .primary-nav a { color: var(--text-muted); font-weight: 500; }
  .site-header .primary-nav a:hover { color: var(--text); text-decoration: none; }
  /* Right-anchored "Log in" pill — visually separates the call-to-action
     from the regular nav links so signed-out visitors find the entry point. */
  .site-header .primary-nav .nav-login {
    margin-left: 8px;
    padding: 8px 16px;
    border-radius: var(--r-pill);
    background: var(--primary);
    color: white;
    font-weight: 600;
  }
  .site-header .primary-nav .nav-login:hover { background: var(--primary-hover); color: white; }

  /* Hamburger button — desktop hidden, mobile visible. Three-bar icon
     animates into an X when open. */
  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    color: var(--text);
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .nav-toggle:hover { background: var(--surface-2); }
  .nav-toggle-bars {
    display: grid;
    gap: 4px;
    width: 18px;
  }
  .nav-toggle-bars > span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.18s ease, opacity 0.18s ease;
    transform-origin: center;
  }
  .site-header[data-nav-open="true"] .nav-toggle-bars > span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .site-header[data-nav-open="true"] .nav-toggle-bars > span:nth-child(2) {
    opacity: 0;
  }
  .site-header[data-nav-open="true"] .nav-toggle-bars > span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 720px) {
    .nav-toggle { display: inline-flex; }

    /* Drawer mode: nav slides down from below the header on mobile.
       Hidden by default, revealed by data-nav-open="true" on the header. */
    .site-header .primary-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 16px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.18);
      /* Hide via clip-path so display:none doesn't interrupt the focus order
         while the menu is open mid-animation. */
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.18s ease, opacity 0.18s ease;
      z-index: 5;
    }
    .site-header[data-nav-open="true"] .primary-nav {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .site-header .primary-nav a {
      padding: 14px 12px;
      border-radius: var(--r-md);
      font-size: 16px;
    }
    .site-header .primary-nav a:hover { background: var(--surface-2); }
    .site-header .primary-nav .nav-login {
      margin-left: 0;
      margin-top: 8px;
      text-align: center;
    }
  }

  /* Footer — full-bleed band so the page closes cleanly. The brand
     column on the left re-states the pitch and gives signed-out users
     a second chance to drop their email; link columns on the right
     cover product/company/legal. The faint baseline strip at the bottom
     carries copyright + a launch-status reminder. */
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 96px;
    padding: 56px 24px 24px;
    background: var(--surface);
    color: var(--text-muted);
    font-size: 14px;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }
  .footer-brand { max-width: 360px; }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter Display', 'Inter', sans-serif;
    font-weight: 600;
    color: var(--text);
    font-size: 17px;
  }
  .footer-logo:hover { text-decoration: none; color: var(--text); }
  .footer-tag {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 14px 0 18px;
  }
  /* Footer secondary CTA — points footer-curious visitors to the blog
     (the App Store + web-app links live in the baseline status line). */
  .footer-blog-cta {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s ease, transform 0.15s ease;
    max-width: 360px;
  }
  .footer-blog-cta:hover {
    border-color: var(--primary);
    text-decoration: none;
    transform: translateY(-1px);
  }
  .footer-blog-cta-title {
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
  }
  .footer-blog-cta-sub {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.45;
  }
  .footer-blog-cta-link {
    font-size: 13px;
    color: var(--primary);
    font-weight: 600;
    margin-top: 4px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 480px) {
    .footer-links { grid-template-columns: repeat(2, 1fr); }
  }
  .footer-col { display: flex; flex-direction: column; gap: 8px; }
  .footer-col h4 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 6px;
  }
  .footer-col a {
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
  }
  .footer-col a:hover { color: var(--text); text-decoration: none; }

  .footer-baseline {
    max-width: 1100px;
    margin: 32px auto 0;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-muted);
    flex-wrap: wrap;
    gap: 8px;
  }
  .footer-baseline .status-line { font-style: italic; }
  .footer-baseline .status-line a {
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    font-style: italic;
  }
  .footer-baseline .status-line a:hover { color: var(--primary); }
</style>
