---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Checkout cancelled — Macroline"
  description="No charge was made. You can try again any time."
>
  <section class="billing">
    <div class="x">×</div>
    <h1>No charge was made.</h1>
    <p class="lede">You backed out of checkout. Nothing was charged. Your account is still on the free tier.</p>

    <div class="next-steps">
      <h2>Open the app to continue</h2>
      <p>If you'd like to try again, tap <strong>Subscription</strong> in Settings. Or just keep using the free tier — most of Macroline works without Pro.</p>
      <a href="macroline://" class="btn-primary">Open Macroline</a>
      <a href="/" class="btn-ghost">Back to homepage</a>
    </div>

    <div class="free-tier">
      <h3>What you get on free</h3>
      <ul>
        <li>Unlimited barcode scans (search the database)</li>
        <li>Manual food logging + diary</li>
        <li>Goal setting + daily summaries</li>
        <li>3 AI describe-meal calls per day</li>
      </ul>
      <p>Pro unlocks unlimited AI input, the research agent for missing foods, MCP/Claude integration, and full history.</p>
    </div>
  </section>
</Base>

<style>
  .billing {
    max-width: 560px;
    margin: 0 auto;
    padding: 80px 0 60px;
    text-align: center;
  }
  .x {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--surface-2);
    color: var(--text-muted);
    font-size: 38px;
    line-height: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }
  h1 {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }
  .lede {
    font-size: 17px;
    color: var(--text-muted);
    margin: 18px auto 0;
    line-height: 1.5;
    max-width: 440px;
  }
  .next-steps {
    margin-top: 40px;
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
  }
  .next-steps h2 { font-size: 20px; }
  .next-steps p { color: var(--text-muted); margin: 12px 0 18px; line-height: 1.55; }
  .btn-primary, .btn-ghost {
    display: inline-block;
    padding: 12px 24px;
    border-radius: var(--r-pill);
    font-weight: 600;
    text-decoration: none;
    margin: 0 4px;
  }
  .btn-primary {
    background: var(--primary);
    color: white;
  }
  .btn-primary:hover { background: var(--primary-hover); text-decoration: none; }
  .btn-ghost {
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-2); text-decoration: none; }

  .free-tier {
    margin-top: 32px;
    text-align: left;
    padding: 24px;
    background: var(--surface-2);
    border-radius: var(--r-md);
  }
  .free-tier h3 { font-size: 15px; margin-bottom: 12px; }
  .free-tier ul { padding-left: 1.4em; margin: 0 0 14px; color: var(--text-muted); line-height: 1.7; }
  .free-tier p { font-size: 14px; color: var(--text-muted); margin: 0; line-height: 1.55; }
</style>
