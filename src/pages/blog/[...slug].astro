---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatted = post.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Base
  title={`${post.data.title} — Macroline`}
  description={post.data.description}
>
  <article class="post">
    <header class="post-header">
      <a href="/blog" class="back-link">← Blog</a>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>{formatted}</time>
        {post.data.author && <span> · {post.data.author}</span>}
        {post.data.tags.length > 0 && (
          <span class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      <h2>Want this in your phone?</h2>
      <p>Macroline launches first on iOS. Drop your email and we'll let you know.</p>
      <form class="signup-form" action="https://api.macroline.app/api/waitlist" method="post">
        <input type="email" name="email" placeholder="you@example.com" required />
        <button type="submit">Join waitlist</button>
      </form>
    </footer>
  </article>
</Base>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 0 60px;
  }
  .post-header { margin-bottom: 40px; }
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 24px;
  }
  .back-link:hover { color: var(--text); text-decoration: none; }
  .post h1 {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .post-description {
    font-size: 18px;
    color: var(--text-muted);
    margin: 16px 0 0;
    line-height: 1.5;
  }
  .post-meta {
    margin-top: 18px;
    color: var(--text-muted);
    font-size: 13px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .tags { display: inline-flex; gap: 6px; margin-left: 4px; }
  .tag {
    font-size: 11px;
    padding: 3px 8px;
    background: var(--surface-2);
    border-radius: var(--r-pill);
    color: var(--text);
  }

  .post-body :global(p) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text);
    margin: 1.2em 0;
  }
  .post-body :global(h2) {
    font-size: 28px;
    line-height: 1.2;
    margin: 2em 0 0.6em;
    letter-spacing: -0.02em;
  }
  .post-body :global(h3) {
    font-size: 20px;
    line-height: 1.3;
    margin: 1.6em 0 0.4em;
  }
  .post-body :global(strong) { color: var(--text); }
  .post-body :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--primary);
    margin: 1.5em 0;
    padding: 4px 0 4px 18px;
    color: var(--text-muted);
    font-style: italic;
  }
  .post-body :global(hr) {
    margin: 3em 0;
    border: 0;
    height: 1px;
    background: var(--border);
  }
  .post-body :global(code) {
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .post-body :global(ul), .post-body :global(ol) {
    line-height: 1.7;
    margin: 1.2em 0;
    padding-left: 1.4em;
  }
  .post-body :global(li) { margin-bottom: 0.4em; }

  .post-footer {
    margin-top: 60px;
    padding: 40px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-align: center;
  }
  .post-footer h2 { font-size: 26px; }
  .post-footer p { color: var(--text-muted); margin-top: 10px; }
  .signup-form {
    display: flex;
    gap: 8px;
    margin-top: 22px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .signup-form input {
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    font-size: 15px;
    min-width: 240px;
    background: var(--bg);
    color: var(--text);
  }
  .signup-form button {
    padding: 12px 20px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    cursor: pointer;
  }
</style>
