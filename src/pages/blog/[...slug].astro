---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const author = post.data.author && post.data.author !== 'macroline'
  ? await getEntry('authors', post.data.author)
  : null;

const formatted = post.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Base
  title={`${post.data.title} — Macroline`}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <article class="post">
    <header class="post-header">
      <a href="/blog" class="back-link">← Blog</a>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      <div class="post-meta">
        {author && (
          <a href={`/blog/by/${author.id}`} class="author-line">
            <img src={author.data.photo} alt={author.data.name} class="author-avatar" />
            <span class="author-name">{author.data.name}</span>
          </a>
        )}
        <time datetime={post.data.publishedAt.toISOString()}>{formatted}</time>
        {post.data.tags.length > 0 && (
          <span class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    {author && (
      <aside class="author-card">
        <img src={author.data.photo} alt={author.data.name} class="author-card-photo" />
        <div class="author-card-body">
          <p class="author-card-role">{author.data.role}</p>
          <h3 class="author-card-name">{author.data.name}</h3>
          <p class="author-card-bio">{author.data.bio}</p>
          <a href={`/blog/by/${author.id}`} class="author-card-link">More from {author.data.name.split(' ')[0]} →</a>
        </div>
      </aside>
    )}

    <footer class="post-footer">
      <h2>Want this in your phone?</h2>
      <p>Macroline launches first on iOS. Drop your email and we'll let you know.</p>
      <form class="signup-form waitlist-form" action="https://api.macroline.app/api/waitlist" method="post" data-source={`blog:${post.id}`}>
        <div class="hp-field" aria-hidden="true">
          <label>Website (leave blank)<input type="text" name="hp" tabindex="-1" autocomplete="off" /></label>
        </div>
        <input type="email" name="email" placeholder="you@example.com" required />
        <button type="submit">Join waitlist</button>
        <p class="waitlist-msg" role="status" aria-live="polite"></p>
      </form>
    </footer>
  </article>
</Base>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 0 60px;
  }
  .post-header { margin-bottom: 40px; }
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 24px;
  }
  .back-link:hover { color: var(--text); text-decoration: none; }
  .post h1 {
    font-size: clamp(32px, 5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .post-description {
    font-size: 18px;
    color: var(--text-muted);
    margin: 16px 0 0;
    line-height: 1.5;
  }
  .post-meta {
    margin-top: 22px;
    color: var(--text-muted);
    font-size: 13px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .author-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text);
    font-weight: 500;
    text-decoration: none;
  }
  .author-line:hover { text-decoration: none; }
  .author-line:hover .author-name { color: var(--primary); }
  .author-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }
  .tags { display: inline-flex; gap: 6px; margin-left: 4px; }
  .tag {
    font-size: 11px;
    padding: 3px 8px;
    background: var(--surface-2);
    border-radius: var(--r-pill);
    color: var(--text);
  }

  .post-body :global(p) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text);
    margin: 1.2em 0;
  }
  .post-body :global(h2) {
    font-size: 28px;
    line-height: 1.2;
    margin: 2em 0 0.6em;
    letter-spacing: -0.02em;
  }
  .post-body :global(h3) {
    font-size: 20px;
    line-height: 1.3;
    margin: 1.6em 0 0.4em;
  }
  .post-body :global(strong) { color: var(--text); }
  .post-body :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--primary);
    margin: 1.5em 0;
    padding: 4px 0 4px 18px;
    color: var(--text-muted);
    font-style: italic;
  }
  .post-body :global(hr) {
    margin: 3em 0;
    border: 0;
    height: 1px;
    background: var(--border);
  }
  .post-body :global(code) {
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .post-body :global(ul), .post-body :global(ol) {
    line-height: 1.7;
    margin: 1.2em 0;
    padding-left: 1.4em;
  }
  .post-body :global(li) { margin-bottom: 0.4em; }

  .author-card {
    margin-top: 60px;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 20px;
    align-items: start;
  }
  @media (max-width: 540px) {
    .author-card { grid-template-columns: 1fr; }
    .author-card-photo { margin: 0 auto; }
  }
  .author-card-photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
  }
  .author-card-role {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
    margin: 0 0 4px;
  }
  .author-card-name {
    font-size: 20px;
    margin: 0 0 8px;
  }
  .author-card-bio {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 12px;
  }
  .author-card-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--primary);
  }

  .post-footer {
    margin-top: 60px;
    padding: 40px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-align: center;
  }
  .post-footer h2 { font-size: 26px; }
  .post-footer p { color: var(--text-muted); margin-top: 10px; }
  .signup-form {
    display: flex;
    gap: 8px;
    margin-top: 22px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .signup-form input {
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    font-size: 15px;
    min-width: 240px;
    background: var(--bg);
    color: var(--text);
  }
  .signup-form button {
    padding: 12px 20px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    cursor: pointer;
  }
</style>
