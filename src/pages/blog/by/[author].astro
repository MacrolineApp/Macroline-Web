---
import Base from '../../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author) => ({ params: { author: author.id }, props: { author } }));
}

const { author } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const authorPosts = allPosts
  .filter((p) => p.data.author === author.id)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Base
  title={`${author.data.name} — Macroline Blog`}
  description={author.data.bio}
>
  <section class="author-hero">
    <a href="/blog" class="back-link">← All posts</a>
    <img src={author.data.photo} alt={author.data.name} class="hero-photo" />
    <p class="role">{author.data.role}</p>
    <h1>{author.data.name}</h1>
    <p class="bio">{author.data.bio}</p>
    {author.data.expertise.length > 0 && (
      <div class="expertise">
        {author.data.expertise.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </section>

  <section class="post-list">
    <h2 class="section-label">Posts by {author.data.name.split(' ')[0]} ({authorPosts.length})</h2>
    {authorPosts.length === 0 ? (
      <p class="empty">No posts yet from {author.data.name.split(' ')[0]}.</p>
    ) : (
      authorPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-row">
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))
    )}
  </section>
</Base>

<style>
  .author-hero {
    text-align: center;
    padding: 50px 0 40px;
    max-width: 600px;
    margin: 0 auto;
  }
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 24px;
  }
  .back-link:hover { color: var(--text); text-decoration: none; }
  .hero-photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 18px;
  }
  .role {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
    margin: 0 0 8px;
  }
  .author-hero h1 {
    font-size: clamp(32px, 5vw, 44px);
    letter-spacing: -0.03em;
  }
  .bio {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 16px auto 0;
    max-width: 480px;
  }
  .expertise {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-top: 18px;
  }
  .tag {
    font-size: 11px;
    padding: 4px 10px;
    background: var(--surface-2);
    border-radius: var(--r-pill);
    color: var(--text);
  }

  .section-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
    margin: 40px 0 20px;
    text-align: center;
  }
  .post-list { max-width: 720px; margin: 0 auto; }
  .empty { text-align: center; color: var(--text-muted); padding: 40px 0; }
  .post-row {
    display: block;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
  }
  .post-row:hover { text-decoration: none; }
  .post-row:hover h3 { color: var(--primary); }
  .post-row time { font-size: 12px; color: var(--text-muted); }
  .post-row h3 { font-size: 22px; line-height: 1.3; margin: 6px 0 8px; }
  .post-row p { color: var(--text-muted); margin: 0; line-height: 1.55; }
</style>
