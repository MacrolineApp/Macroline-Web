---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Resolve author for each post
const postsWithAuthors = await Promise.all(
  posts.map(async (post) => {
    const author = post.data.author && post.data.author !== 'macroline'
      ? await getEntry('authors', post.data.author)
      : null;
    return { post, author };
  }),
);

const authors = await getCollection('authors');
---

<Base
  title="Blog — Macroline"
  description="Notes on AI macro tracking, GLP-1, and food data done right."
  ogImage="/og-blog.png"
>
  <section class="blog-hero">
    <p class="eyebrow">The Macroline Blog</p>
    <h1>Notes from a tracker built differently.</h1>
    <p class="lede">
      AI-native macro tracking, GLP-1 and nutrition science, what makes food data
      actually trustworthy.
    </p>
  </section>

  {authors.length > 0 && (
    <section class="contributors">
      <h2 class="section-label">Writers</h2>
      <div class="author-grid">
        {authors.map((author) => (
          <a href={`/blog/by/${author.id}`} class="author-chip">
            <img src={author.data.photo} alt={author.data.name} />
            <div>
              <span class="chip-name">{author.data.name}</span>
              <span class="chip-role">{author.data.role}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="post-list">
    {postsWithAuthors.map(({ post, author }) => (
      <a href={`/blog/${post.id}`} class="post-card">
        <div class="post-meta">
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString('en-US', {
              year: 'numeric', month: 'short', day: 'numeric',
            })}
          </time>
          {post.data.tags.length > 0 && (
            <span class="post-tags">{post.data.tags.slice(0, 2).join(' · ')}</span>
          )}
        </div>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
        <div class="post-footer">
          {author && (
            <div class="post-author">
              <img src={author.data.photo} alt={author.data.name} />
              <span>{author.data.name}</span>
            </div>
          )}
          <span class="read-more">Read →</span>
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  /* Navy hero band — matches /pricing and / so blog visitors land in
     the same brand world. Breaks out of the constrained <main> via
     viewport-relative margins, then re-constrains its content. */
  .blog-hero {
    margin-inline: calc(50% - 50vw);
    padding-inline: max(24px, calc(50vw - 538px));
    padding-block: 72px 56px;
    text-align: center;
    background:
      radial-gradient(ellipse 700px 480px at 92% 8%, rgba(91, 158, 255, 0.22) 0%, transparent 55%),
      radial-gradient(ellipse 600px 420px at 4% 96%, rgba(139, 108, 255, 0.16) 0%, transparent 60%),
      linear-gradient(180deg, #0E1A35 0%, #0A1628 60%, #061029 100%);
    color: #F8FAFC;
    border-bottom: 1px solid rgba(96, 165, 250, 0.12);
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    color: #5B9EFF;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }
  .blog-hero h1 {
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    max-width: 720px;
    margin: 0 auto;
  }
  .lede {
    font-size: 17px;
    color: #94B3D7;
    margin: 18px auto 0;
    max-width: 560px;
    line-height: 1.55;
  }

  .section-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
    margin: 0 0 16px;
  }
  .contributors {
    margin-top: 50px;
    padding: 24px 0 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .author-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  .author-chip {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s ease;
  }
  .author-chip:hover {
    border-color: var(--primary);
    text-decoration: none;
  }
  .author-chip img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
  }
  .author-chip > div { display: flex; flex-direction: column; }
  .chip-name { font-weight: 600; font-size: 14px; }
  .chip-role { font-size: 12px; color: var(--text-muted); }

  .post-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 28px;
    color: var(--text);
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--primary);
    text-decoration: none;
  }
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 14px;
  }
  .post-tags { font-weight: 500; }
  .post-card h2 {
    font-size: 22px;
    line-height: 1.2;
    margin: 0 0 12px;
  }
  .post-card p {
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 18px;
    flex: 1;
  }
  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .post-author {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text);
    font-weight: 500;
  }
  .post-author img {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
  }
  .read-more {
    color: var(--primary);
    font-size: 13px;
    font-weight: 600;
  }
</style>
