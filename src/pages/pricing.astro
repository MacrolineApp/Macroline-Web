---
import Base from '../layouts/Base.astro';
---

<Base
  title="Pricing — Macroline"
  description="Free tier covers daily use. Pro is $4.99/mo (or $39/year) and unlocks unlimited AI meal logging plus Claude integration."
>
  <section class="hero">
    <p class="eyebrow">Pricing</p>
    <h1>Honest pricing.<br/>Just like the data.</h1>
    <p class="lede">Free tier covers daily use. Pro adds the AI features that make Macroline feel magic.</p>
  </section>

  <!-- Billing toggle — defaults to annual (better-converting + lower churn).
       Persisted in sessionStorage so navigating /pricing → /features → back
       remembers the choice. data-billing attribute on the .tiers element
       drives all the price-swap CSS below. -->
  <div class="billing-toggle" role="group" aria-label="Billing period">
    <button type="button" data-bill="monthly" aria-pressed="false">Monthly</button>
    <button type="button" data-bill="annual" aria-pressed="true">Annual <span class="save-pill">save 35%</span></button>
  </div>

  <section class="tiers" data-billing="annual">
    <div class="tier free">
      <h2>Free</h2>
      <div class="price">$0<span>forever</span></div>

      <p class="tier-section-label">Included</p>
      <ul class="features-list">
        <li>✓ Unlimited food logging</li>
        <li>✓ Search USDA + barcoded products</li>
        <li>✓ Daily macro dashboard</li>
        <li>✓ Goals &amp; weight tracking</li>
        <li>✓ 5 saved meals</li>
        <li>✓ 30-day history</li>
      </ul>

      <p class="tier-section-label">Daily limits</p>
      <ul class="limits-list">
        <li><span class="limit-x" aria-hidden="true">✕</span> 5 barcode scans</li>
        <li><span class="limit-x" aria-hidden="true">✕</span> 3 AI meal descriptions</li>
        <li><span class="limit-x" aria-hidden="true">✕</span> No research agent</li>
        <li><span class="limit-x" aria-hidden="true">✕</span> No Claude integration</li>
      </ul>

      <a href="https://my.macroline.app/signup" class="btn-ghost">Start free</a>
    </div>

    <div class="tier pro">
      <span class="badge">Recommended</span>
      <h2>Pro</h2>
      <div class="price-block">
        <div class="price price-annual">
          <span class="price-amount">$3.25</span><span class="price-unit">/mo</span>
        </div>
        <p class="price-caption price-caption-annual">billed annually ($39) · save $20 a year</p>
        <div class="price price-monthly">
          <span class="price-amount">$4.99</span><span class="price-unit">/mo</span>
        </div>
        <p class="price-caption price-caption-monthly">billed monthly</p>
      </div>

      <p class="trial-pill">✨ 7-day free trial · cancel anytime</p>

      <ul class="features-list">
        <li>✓ Everything in Free</li>
        <li>✓ <strong>Unlimited AI meal descriptions</strong></li>
        <li>✓ <strong>Unlimited barcode scans</strong></li>
        <li>✓ <strong>Research agent</strong> auto-finds missing chain restaurant foods</li>
        <li>✓ <strong>MCP server</strong> — connect Claude or any MCP assistant</li>
        <li>✓ Full unlimited history</li>
        <li>✓ Unlimited saved meals &amp; recipes</li>
        <li>✓ CSV export</li>
        <li>✓ Public REST API access (per-user keys)</li>
      </ul>

      <a href="https://my.macroline.app/signup?plan=pro" class="btn-primary">Go Pro</a>
    </div>
  </section>

  <section class="comparison">
    <h2>Why we charge for Pro</h2>
    <p>
      Macroline's research agent and AI input call out to Claude on every miss. That costs us per-call.
      Free-tier quotas keep the lights on without ads, dark patterns, or selling your data. Pro is the
      sustainable way to use the magic features — and the entire database benefits, since researched
      foods get cached for everyone.
    </p>
  </section>
</Base>

<script>
  // Billing toggle — vanilla JS, no framework. The .tiers element carries
  // data-billing="annual" | "monthly" which the CSS keys all price swaps
  // off of. sessionStorage persists the choice so cross-page navigation
  // within a session preserves the user's selected view.
  //
  // Storage key matches the brief's behavioral contract:
  // sessionStorage.macroline.billing
  const STORAGE_KEY = 'macroline.billing';
  const tiersEl = document.querySelector('.tiers');
  const buttons = document.querySelectorAll<HTMLButtonElement>('.billing-toggle button[data-bill]');

  function setBilling(value: 'annual' | 'monthly') {
    if (!tiersEl) return;
    tiersEl.setAttribute('data-billing', value);
    buttons.forEach((b) => {
      const isActive = b.dataset.bill === value;
      b.setAttribute('aria-pressed', String(isActive));
      b.classList.toggle('is-active', isActive);
    });
    try {
      sessionStorage.setItem(STORAGE_KEY, value);
    } catch {
      // sessionStorage can throw in some embedded WebViews; non-fatal.
    }
  }

  // Restore prior selection (defaults to annual via initial data-billing).
  try {
    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved === 'monthly' || saved === 'annual') setBilling(saved);
    else setBilling('annual');
  } catch {
    setBilling('annual');
  }

  buttons.forEach((b) => {
    b.addEventListener('click', () => {
      const value = b.dataset.bill === 'monthly' ? 'monthly' : 'annual';
      setBilling(value);
    });
  });
</script>

<style>
  /* Navy hero band — mirrors the homepage pattern. Breaks out of the
     constrained <main>, then re-constrains its content. Keeps the marketing
     → install visual handoff consistent across pages. */
  .hero {
    margin-inline: calc(50% - 50vw);
    padding-inline: max(24px, calc(50vw - 538px));
    padding-block: 80px 64px;
    text-align: center;
    background:
      radial-gradient(ellipse 700px 480px at 92% 8%, rgba(91, 158, 255, 0.22) 0%, transparent 55%),
      radial-gradient(ellipse 600px 420px at 4% 96%, rgba(139, 108, 255, 0.16) 0%, transparent 60%),
      linear-gradient(180deg, #0E1A35 0%, #0A1628 60%, #061029 100%);
    color: #F8FAFC;
    border-bottom: 1px solid rgba(96, 165, 250, 0.12);
  }
  .hero .eyebrow {
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: #5B9EFF;
    margin: 0 0 14px;
  }
  .hero h1 {
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }
  .hero .lede {
    color: #94B3D7;
    font-size: 17px;
    margin: 18px auto 0;
    max-width: 560px;
    line-height: 1.55;
  }

  /* Billing toggle — segmented pill above the price cards. */
  .billing-toggle {
    display: inline-flex;
    margin: 32px auto 0;
    padding: 4px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    gap: 4px;
    align-self: center;
  }
  .billing-toggle {
    display: flex;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .billing-toggle button {
    padding: 8px 18px;
    background: transparent;
    border: none;
    border-radius: var(--r-pill);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .billing-toggle button.is-active {
    background: var(--primary);
    color: white;
  }
  .billing-toggle button:hover:not(.is-active) { color: var(--text); }
  .save-pill {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: var(--r-pill);
    background: color-mix(in srgb, var(--protein) 25%, transparent);
    color: var(--protein);
  }
  .billing-toggle button.is-active .save-pill {
    background: rgba(255, 255, 255, 0.18);
    color: white;
  }

  .tiers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 800px;
    margin: 20px auto 0;
  }
  @media (max-width: 720px) { .tiers { grid-template-columns: 1fr; } }

  .tier {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 32px;
  }
  .tier.pro {
    border: 2px solid var(--primary);
  }
  .badge {
    position: absolute;
    top: -10px;
    left: 24px;
    background: var(--primary);
    color: white;
    padding: 4px 12px;
    border-radius: var(--r-pill);
    font-size: 12px;
    font-weight: 600;
  }
  .tier h2 { font-size: 22px; margin-bottom: 8px; }
  .price {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .price span { font-size: 15px; font-weight: 400; color: var(--text-muted); margin-left: 6px; }
  .price-amount { display: inline; }
  .price-unit {
    font-size: 15px;
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 4px;
  }
  .price-caption {
    color: var(--text-muted);
    font-size: 13px;
    margin: 6px 0 0;
  }

  /* Annual vs monthly: show the matching block, hide the other. The
     data-billing attribute on .tiers gates which one is visible. */
  .price-block .price-annual,
  .price-block .price-caption-annual {
    display: none;
  }
  .price-block .price-monthly,
  .price-block .price-caption-monthly {
    display: none;
  }
  .tiers[data-billing="annual"] .price-annual,
  .tiers[data-billing="annual"] .price-caption-annual {
    display: block;
  }
  .tiers[data-billing="monthly"] .price-monthly,
  .tiers[data-billing="monthly"] .price-caption-monthly {
    display: block;
  }

  /* 7-day trial pill — sits between price and feature list on the Pro card. */
  .trial-pill {
    display: inline-block;
    margin: 14px 0 0;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--primary);
    border-radius: var(--r-pill);
    font-size: 12px;
    font-weight: 600;
  }

  /* Split-section labels above the Included / Daily limits lists in Free.
     Pro reuses the same Included list (no limits section). */
  .tier-section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 24px 0 8px;
  }
  .tier.pro .tier-section-label:first-of-type { margin-top: 22px; }

  .features-list, .limits-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .features-list li, .limits-list li {
    padding: 6px 0;
    font-size: 14px;
    color: var(--text);
    line-height: 1.45;
  }
  /* Daily-limits rows use a small ✕ glyph in dimmed text — not red (this
     is "not included," not "error"). */
  .limits-list li {
    color: var(--text-muted);
  }
  .limit-x {
    display: inline-block;
    width: 16px;
    color: var(--text-muted);
    font-weight: 600;
    margin-right: 4px;
  }

  .btn-primary, .btn-ghost {
    display: block;
    text-align: center;
    padding: 14px;
    border-radius: var(--r-pill);
    font-weight: 600;
    text-decoration: none;
    margin-top: 20px;
  }
  .btn-primary { background: var(--primary); color: white; }
  .btn-primary:hover { background: var(--primary-hover); color: white; text-decoration: none; }
  .btn-ghost { color: var(--text); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--primary); color: var(--text); text-decoration: none; }

  .comparison {
    margin-top: 60px;
    text-align: center;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .comparison h2 { font-size: 24px; }
  .comparison p { color: var(--text-muted); margin-top: 12px; }
</style>
