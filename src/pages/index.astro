---
import Base from '../layouts/Base.astro';
---

<Base>
  <section class="hero">
    <h1>Just say what you ate.</h1>
    <p class="hero-sub">
      The AI-native macro &amp; calorie tracker. Describe a meal in plain English,
      scan a barcode, or connect Claude — every food has a verified source.
    </p>
    <div class="cta-row">
      <a href="#download" class="btn-primary">Get Macroline</a>
      <a href="/pricing" class="btn-ghost">See pricing</a>
    </div>
    <p class="cta-sub">Free tier with all the basics · Pro $4.99/mo unlocks AI input + Claude integration</p>
  </section>

  <section class="pillars">
    <article class="pillar">
      <div class="pillar-icon">🎙</div>
      <h2>Speak it. Log it.</h2>
      <p>"I had a chicken caesar wrap with extra parmesan and a coke." Macroline parses natural language, finds the right foods, and logs the right portions. Voice or text, your call.</p>
    </article>

    <article class="pillar">
      <div class="pillar-icon">🔍</div>
      <h2>Honest data.</h2>
      <p>Every food links to its source — USDA, manufacturer pages, official restaurant nutrition. Tap any number to see where it came from. No more bad community entries with wrong macros.</p>
    </article>

    <article class="pillar">
      <div class="pillar-icon">🔌</div>
      <h2>Bring your own AI.</h2>
      <p>Macroline runs as an MCP server. Connect Claude, ChatGPT, or any MCP-compatible assistant. Log dinner from your phone, your desktop, even your IDE.</p>
    </article>
  </section>

  <section class="moat">
    <h2>Every number, sourced.</h2>
    <p class="moat-lede">
      Macroline is built on a different principle than MyFitnessPal: <strong>show your work.</strong>
      Every food row in our database carries a provenance tier and a citation URL.
    </p>
    <div class="tier-grid">
      <div class="tier authoritative">
        <span class="tier-dot"></span>
        <h3>Authoritative</h3>
        <p>USDA FoodData Central, manufacturer pages, official chain restaurant nutrition. The gold standard.</p>
      </div>
      <div class="tier computed">
        <span class="tier-dot"></span>
        <h3>Computed</h3>
        <p>Recipe foods derived from authoritative ingredients with summed macros. Math is verifiable.</p>
      </div>
      <div class="tier estimated">
        <span class="tier-dot"></span>
        <h3>Estimated</h3>
        <p>AI-researched from cross-checked sources when no official data exists. Cited and flagged.</p>
      </div>
      <div class="tier unverified">
        <span class="tier-dot"></span>
        <h3>Unverified</h3>
        <p>User-submitted entries, awaiting community confirmation. Visible but never silently trusted.</p>
      </div>
    </div>
  </section>

  <section id="download" class="download">
    <h2>Coming soon to the App Store.</h2>
    <p>Macroline launches first on iOS via TestFlight. Drop your email and we'll let you know.</p>
    <form class="signup-form" action="https://api.macroline.app/api/waitlist" method="post">
      <input type="email" name="email" placeholder="you@example.com" required />
      <button type="submit">Join waitlist</button>
    </form>
  </section>
</Base>

<style>
  .hero {
    padding: 80px 0 40px;
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .hero-sub {
    font-size: 19px;
    color: var(--text-muted);
    margin: 24px auto 0;
    max-width: 560px;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .btn-primary, .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 14px 24px;
    border-radius: var(--r-pill);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--primary);
    color: white;
  }
  .btn-primary:hover { background: var(--primary-hover); text-decoration: none; }
  .btn-ghost {
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-2); text-decoration: none; }
  .cta-sub { color: var(--text-muted); font-size: 13px; margin-top: 16px; }

  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 60px;
  }
  .pillar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 28px;
  }
  .pillar-icon { font-size: 28px; margin-bottom: 12px; }
  .pillar h2 { font-size: 22px; margin-bottom: 8px; }
  .pillar p { color: var(--text-muted); margin: 0; line-height: 1.6; }

  .moat {
    margin-top: 100px;
    text-align: center;
  }
  .moat h2 { font-size: clamp(28px, 4vw, 44px); }
  .moat-lede { color: var(--text-muted); max-width: 600px; margin: 16px auto 40px; font-size: 17px; }
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    text-align: left;
  }
  .tier {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 20px;
  }
  .tier h3 { font-size: 16px; margin-bottom: 6px; }
  .tier p { font-size: 14px; color: var(--text-muted); margin: 0; }
  .tier-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-bottom: 8px;
  }
  .authoritative .tier-dot { background: #10B981; }
  .computed     .tier-dot { background: #3B82F6; }
  .estimated    .tier-dot { background: #EAB308; }
  .unverified   .tier-dot { background: #94A3B8; }

  .download {
    margin-top: 100px;
    text-align: center;
    padding: 60px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
  }
  .download h2 { font-size: 32px; }
  .download p { color: var(--text-muted); margin-top: 12px; }
  .signup-form {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .signup-form input {
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    font-size: 15px;
    min-width: 240px;
    background: var(--bg);
    color: var(--text);
  }
  .signup-form button {
    padding: 12px 20px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    cursor: pointer;
  }
</style>
