</Base>

<style>
  .prose {
    max-width: 760px;
    margin: 60px auto;
    padding: 0 24px 80px;
    line-height: 1.7;
  }
  .prose h1 { font-size: 36px; }
  .prose h2 {
    font-size: 22px;
    margin-top: 40px;
    margin-bottom: 12px;
    border-top: 1px solid var(--border);
    padding-top: 32px;
  }
  .prose h2:first-of-type { border-top: none; padding-top: 0; }
  .prose h3 {
    font-size: 17px;
    margin-top: 24px;
    margin-bottom: 8px;
    color: var(--text);
  }
  .prose .updated {
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 4px;
  }
  .prose p, .prose ul { color: var(--text); }
  .prose ul { padding-left: 24px; }
  .prose li { margin-bottom: 8px; }
  .prose a { color: var(--primary); }
  .prose strong { color: var(--text); }

  .tldr {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--primary);
    border-radius: var(--r-md);
    padding: 16px 20px;
    margin: 24px 0 32px;
    font-size: 15px;
  }
  .warn {
    background: color-mix(in srgb, var(--carbs) 12%, transparent);
    border-left: 4px solid var(--carbs);
    border-radius: var(--r-md);
    padding: 14px 18px;
    font-size: 15px;
  }
  .footer-note {
    color: var(--text-muted);
    font-size: 13px;
    margin-top: 24px;
  }
</style>
